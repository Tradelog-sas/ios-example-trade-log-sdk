# Credenciales/config del SDK de Tradelog.
# Copia este archivo a `.env` y pon tus valores reales. `.env` está en .gitignore.
# El Makefile genera Sources/Generated/AppConfig.generated.swift a partir de aquí.

TRADELOG_API_KEY=YOUR_API_KEY
TRADELOG_TENANT_ID=YOUR_TENANT_ID
TRADELOG_ENVIRONMENT=staging          # staging | production
TRADELOG_ENABLE_LOGS=true             # true | false
TRADELOG_CUSTOMER_NAME=Client Demo
TRADELOG_CUSTOMER_DATA=client@example.com
